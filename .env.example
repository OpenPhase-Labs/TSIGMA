# =============================================================================
# TSIGMA Configuration
# Copy to .env and edit for your environment.
# All variables use the TSIGMA_ prefix.
# =============================================================================

# --- Database ----------------------------------------------------------------
TSIGMA_DB_TYPE=postgresql
TSIGMA_PG_HOST=localhost
TSIGMA_PG_PORT=5432
TSIGMA_PG_DATABASE=tsigma
TSIGMA_PG_USER=tsigma
TSIGMA_PG_PASSWORD=

# --- Component Toggles ------------------------------------------------------
TSIGMA_ENABLE_API=true
TSIGMA_ENABLE_COLLECTOR=true
TSIGMA_ENABLE_SCHEDULER=true

# --- TimescaleDB Tuning ------------------------------------------------------
TSIGMA_TIMESCALE_CHUNK_INTERVAL=1 day
TSIGMA_STORAGE_WARM_AFTER=7 days
TSIGMA_STORAGE_RETENTION=2 years

# --- Cold Storage (on-prem only) ---------------------------------------------
TSIGMA_STORAGE_COLD_ENABLED=false
TSIGMA_STORAGE_COLD_AFTER=6 months
TSIGMA_STORAGE_COLD_PATH=/var/lib/tsigma/cold

# --- Collector ---------------------------------------------------------------
TSIGMA_COLLECTOR_MAX_CONCURRENT=50
TSIGMA_COLLECTOR_POLL_INTERVAL=300

# --- API Server --------------------------------------------------------------
TSIGMA_API_HOST=0.0.0.0
TSIGMA_API_PORT=8080

# --- CORS (comma-separated origins) -----------------------------------------
TSIGMA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging -----------------------------------------------------------------
TSIGMA_LOG_LEVEL=INFO
TSIGMA_LOG_FORMAT=json

# --- Authentication ----------------------------------------------------------
# Auth mode: "local", "oidc", or "oauth2"
TSIGMA_AUTH_MODE=local
TSIGMA_AUTH_ADMIN_USER=admin
TSIGMA_AUTH_ADMIN_PASSWORD=changeme
TSIGMA_AUTH_SESSION_TTL_MINUTES=480
TSIGMA_AUTH_COOKIE_NAME=tsigma_session
TSIGMA_AUTH_COOKIE_SECURE=false

# --- OIDC (Azure AD / Entra ID) ---------------------------------------------
# Required when TSIGMA_AUTH_MODE=oidc
TSIGMA_OIDC_TENANT_ID=
TSIGMA_OIDC_CLIENT_ID=
TSIGMA_OIDC_CLIENT_SECRET=
TSIGMA_OIDC_SCOPES=openid email profile
TSIGMA_OIDC_REDIRECT_URI=
TSIGMA_OIDC_ADMIN_GROUPS=

# --- Generic OAuth2 ----------------------------------------------------------
# Required when TSIGMA_AUTH_MODE=oauth2
TSIGMA_OAUTH2_ISSUER_URL=
TSIGMA_OAUTH2_CLIENT_ID=
TSIGMA_OAUTH2_CLIENT_SECRET=
TSIGMA_OAUTH2_SCOPES=openid email profile
TSIGMA_OAUTH2_REDIRECT_URI=
TSIGMA_OAUTH2_AUTHORIZATION_ENDPOINT=
TSIGMA_OAUTH2_TOKEN_ENDPOINT=
TSIGMA_OAUTH2_USERINFO_ENDPOINT=
TSIGMA_OAUTH2_ADMIN_GROUPS=
TSIGMA_OAUTH2_USERNAME_CLAIM=email
